pipeline {
    agent any

    environment {
        // Updated for Savantle naming conventions
        IMAGE_NAME = 'savantle-frontend-prd'
        CONTAINER_NAME = 'Savantle-Frontend-PRD'
        DOCKERFILE = 'Dockerfile_PRD'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out the Savantle Frontend project...'
                checkout scm
            }
        }

        stage('Get Version') {
            steps {
                script {
                    def latestTag = sh(script: "git describe --tags --abbrev=0 2>/dev/null || echo '1.0.0'", returnStdout: true).trim()
                    echo "Current Version: ${latestTag}"
                    env.VERSION = latestTag
                    currentBuild.description = "Version: ${env.VERSION}"
                    currentBuild.displayName = "Build #${env.BUILD_NUMBER} - Version: ${env.VERSION}"
                }
            }
        }

        stage('Generate .env File') {
            steps {
                script {
                    echo 'Generating .env file for Savantle...'
                    dir('frontend') {
                        sh """
                            cat <<EOF > .env
                            VITE_API_BASE_URL=https://api.savantle.com/api/v1/savantle
                            EOF
                        """
                    }
                }
            }
        }

        stage('Stop and Remove Existing Container') {
            steps {
                script {
                    echo "Stopping and removing the existing ${env.CONTAINER_NAME} instance..."
                    sh """
                        docker stop ${CONTAINER_NAME} || echo "Savantle is not running."
                        docker rm ${CONTAINER_NAME} || echo "No old Savantle instance to remove."
                    """
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image for Savantle Frontend...'
                dir('frontend') {
                    sh """
                        docker build -f ${DOCKERFILE} -t ${IMAGE_NAME}:latest .
                    """
                }
            }
        }

        stage('Run New Container') {
            steps {
                script {
                    echo 'Running the new container on port 999...'
                    dir('frontend') {
                        sh """
                            docker run -d --name ${CONTAINER_NAME} \
                                -p 999:999 \
                                --env-file .env \
                                ${IMAGE_NAME}:latest
                        """
                    }
                }
            }
        }

        stage('Cleanup') {
            steps {
                script {
                    echo 'Cleaning up sensitive files...'
                    sh 'rm -f frontend/.env'
                }
            }
        }

        stage('Cleanup Docker System') {
            steps {
                script {
                    echo 'Pruning unused Docker resources...'
                    sh 'docker system prune -f'
                }
            }
        }
    }

    post {
        success {
            echo 'Savantle Frontend PRD deployed successfully!'
        }
        failure {
            echo 'Savantle Frontend PRD deployment failed.'
        }
    }
}