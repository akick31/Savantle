pipeline {
    agent any

    environment {
        IMAGE_NAME = 'savantle-frontend-prd'
        CONTAINER_NAME = 'Savantle-Frontend-PRD'
        CONTAINER_NAME_BLUE = 'Savantle-Frontend-PRD-BLUE'
        DOCKERFILE = 'Dockerfile_PRD'
        HEALTH_URL = 'http://localhost:999'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out the Savantle Frontend project...'
                checkout scm
            }
        }

        stage('Get Version') {
            steps {
                script {
                    def latestTag = sh(script: "git describe --tags --abbrev=0 2>/dev/null || echo '1.0.0'", returnStdout: true).trim()
                    env.VERSION = latestTag
                    currentBuild.description = "Version: ${env.VERSION}"
                    currentBuild.displayName = "Build #${env.BUILD_NUMBER} - Version: ${env.VERSION}"
                }
            }
        }

        stage('Generate .env File') {
            steps {
                dir('frontend') {
                    sh """
                        cat <<EOF > .env
                        VITE_API_BASE_URL=https://api.savantle.com/api/v1/savantle
                        EOF
                    """
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('frontend') {
                    sh "docker build -f ${DOCKERFILE} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Start New Container') {
            steps {
                sh "docker rm -f ${CONTAINER_NAME_BLUE} || true"
                sh """
                    docker run -d --name ${CONTAINER_NAME_BLUE} \
                        -p 999:999 \
                        --env-file frontend/.env \
                        ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Health Check') {
            steps {
                script {
                    def healthy = false
                    def attempts = 0
                    def maxAttempts = 24
                    while (!healthy && attempts < maxAttempts) {
                        attempts++
                        try {
                            def status = sh(
                                script: "curl -sf -o /dev/null -w '%{http_code}' ${HEALTH_URL}",
                                returnStdout: true
                            ).trim()
                            if (status == '200') {
                                healthy = true
                                echo "New container is healthy after ${attempts * 5}s"
                            }
                        } catch (e) {
                            // not ready yet
                        }
                        if (!healthy) {
                            echo "Waiting for health check... attempt ${attempts}/${maxAttempts}"
                            sleep 5
                        }
                    }
                    if (!healthy) {
                        sh "docker logs ${CONTAINER_NAME_BLUE} --tail=50"
                        sh "docker rm -f ${CONTAINER_NAME_BLUE} || true"
                        error("New container failed to become healthy after ${maxAttempts * 5}s — rolled back")
                    }
                }
            }
        }

        stage('Swap Containers') {
            steps {
                sh "docker stop ${CONTAINER_NAME} || true"
                sh "docker rm ${CONTAINER_NAME} || true"
                sh "docker rename ${CONTAINER_NAME_BLUE} ${CONTAINER_NAME}"
                sh "docker update --restart=always ${CONTAINER_NAME}"
            }
        }

        stage('Cleanup') {
            steps {
                sh 'rm -f frontend/.env'
                sh 'docker system prune -f'
            }
        }
    }

    post {
        success {
            echo 'Savantle Frontend PRD deployed successfully!'
        }
        failure {
            sh "docker rm -f ${CONTAINER_NAME_BLUE} || true"
            echo 'Savantle Frontend PRD deployment failed.'
        }
    }
}
